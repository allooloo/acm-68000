{
  "name": "acm-68000-tools",
  "description": "ACM-68000 MCP Server function schemas for LLM function calling. Resolve GTIN barcodes to ACM signals (ALLOW/RESTRICT/CONDITIONAL) for product eligibility.",
  "version": "1.0.0",
  "base_url": "https://mcp.10060.ai",
  "operator": "Allooloo Technologies Corp.",
  "protocol": "ACM-68000",
  "tools": [
    {
      "name": "resolve_gtin",
      "description": "Resolve a GTIN barcode to an ACM-68000 signal. Returns ALLOW, RESTRICT, or CONDITIONAL for product eligibility.",
      "endpoint": "/tools/resolve_gtin",
      "method": "GET",
      "parameters": {
        "type": "object",
        "properties": {
          "gtin": {
            "type": "string",
            "description": "The 14-digit GTIN barcode (e.g., '00990832300006')"
          }
        },
        "required": ["gtin"]
      },
      "returns": {
        "type": "object",
        "properties": {
          "gtin": { "type": "string", "description": "The queried GTIN" },
          "signal": { "type": "string", "description": "ACM signal code (ACM-200, ACM-403, etc.)" },
          "state": { "type": "string", "description": "Human-readable state (ALLOW, RESTRICT, CONDITIONAL)" },
          "name": { "type": "string", "description": "Product name" }
        }
      }
    },
    {
      "name": "get_dpu",
      "description": "Get full DPU (Deterministic Product Unit) v1.1 object for a GTIN. Includes jurisdiction list, compliance data, brand, and signal.",
      "endpoint": "/tools/get_dpu",
      "method": "GET",
      "parameters": {
        "type": "object",
        "properties": {
          "gtin": {
            "type": "string",
            "description": "The 14-digit GTIN barcode"
          }
        },
        "required": ["gtin"]
      },
      "returns": {
        "type": "object",
        "properties": {
          "dpu_version": { "type": "string" },
          "gtin": { "type": "string" },
          "name": { "type": "string" },
          "signal": { "type": "string" },
          "state": { "type": "string" },
          "jurisdiction": { "type": "array", "description": "List of authorized ISO country codes" },
          "compliance": { "type": "object", "description": "SGS report, classification, verification status" }
        }
      }
    },
    {
      "name": "check_eligibility",
      "description": "Check if a GTIN is eligible for sale in a specific jurisdiction. Returns eligibility status with reason.",
      "endpoint": "/tools/check_eligibility",
      "method": "GET",
      "parameters": {
        "type": "object",
        "properties": {
          "gtin": {
            "type": "string",
            "description": "The 14-digit GTIN barcode"
          },
          "jurisdiction": {
            "type": "string",
            "description": "ISO country code (e.g., 'US', 'DE', 'FR', 'JP', 'BR')"
          }
        },
        "required": ["gtin", "jurisdiction"]
      },
      "returns": {
        "type": "object",
        "properties": {
          "gtin": { "type": "string" },
          "jurisdiction": { "type": "string" },
          "eligible": { "type": "boolean" },
          "signal": { "type": "string" },
          "state": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    {
      "name": "list_signals",
      "description": "List all 7 ACM-68000 signal definitions with their codes, states, and meanings.",
      "endpoint": "/tools/list_signals",
      "method": "GET",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "returns": {
        "type": "object",
        "properties": {
          "protocol": { "type": "string" },
          "version": { "type": "string" },
          "signals": { "type": "object", "description": "Map of signal codes to definitions" },
          "reference": { "type": "string", "description": "URL to signal reference" }
        }
      }
    },
    {
      "name": "list_products",
      "description": "List all products currently registered on the AIO-TFX Rail.",
      "endpoint": "/tools/list_products",
      "method": "GET",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "returns": {
        "type": "object",
        "properties": {
          "rail": { "type": "string" },
          "rail_url": { "type": "string" },
          "product_count": { "type": "integer" },
          "products": { "type": "array" }
        }
      }
    }
  ],
  "signals": {
    "ACM-000": { "state": "NOT_APPLICABLE", "meaning": "Signal does not govern this SKU or context" },
    "ACM-200": { "state": "ALLOW", "meaning": "Agent may execute the commercial action" },
    "ACM-300": { "state": "CONDITIONAL", "meaning": "Action requires additional conditions" },
    "ACM-403": { "state": "RESTRICT", "meaning": "Action blocked under current conditions" },
    "ACM-404": { "state": "NOT_FOUND", "meaning": "Object not registered in any signal cluster" },
    "ACM-451": { "state": "ESCALATE", "meaning": "Human-in-the-loop required" },
    "ACM-500": { "state": "SYSTEM_ERROR", "meaning": "Infrastructure failure — retry or fallback" }
  }
}
